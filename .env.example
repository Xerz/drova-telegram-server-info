TELEGRAM_BOT_TOKEN=REPLACE-TO-YOUR-TELEGRAM-BOT-TOKEN
# Optional for local non-Docker run. In docker-compose the bot uses the internal xray proxy automatically.
HTTP_PROXY=http://user:pass@127.0.0.1:8080
HTTPS_PROXY=http://user:pass@127.0.0.1:8080
# Optional. Python logging level, e.g. DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Optional. Telegram API/httpx timeouts, useful when the bot works through a proxy.
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=15
TELEGRAM_GET_UPDATES_TIMEOUT=30
